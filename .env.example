# CORNEY — contoh environment. Salin ke `.env.local` lalu isi nilai asli.
# `.env.local` di-gitignore (lihat .gitignore). JANGAN commit kunci asli.
#
# Var berprefix VITE_  -> IKUT ke bundle browser (boleh publik).
# Var TANPA prefix      -> server-side saja (Vite dev middleware / Edge Function).

# ── Supabase (TAHAP 4) — AMAN di browser karena semua tabel dilindungi RLS ──
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Saklar backend: local (default, localStorage) | supabase (pakai DB)
VITE_BACKEND=local

# ── Cloudinary (TAHAP 4 Fase 7) — unsigned upload preset (bukan API Secret) ──
# Cloud name = lihat dashboard Cloudinary. Preset 'corney_unsigned' sudah dibuat.
VITE_CLOUDINARY_CLOUD=your-cloud-name
VITE_CLOUDINARY_PRESET=corney_unsigned

# ── Midtrans (server-side SAJA; TANPA prefix VITE_ → tidak ikut ke browser) ──
# Server Key WAJIB rahasia. Hanya dibaca dev middleware / Edge Function.
MIDTRANS_SERVER_KEY=Mid-server-xxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxx
MIDTRANS_MERCHANT_ID=Gxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
